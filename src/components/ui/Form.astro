---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Send Message', description = '' } = Astro.props;

const WEB3FORMS_KEY = '64a9dcb4-ce93-4b2e-81f0-f8be97f245cd';
---

<!-- Success state -->
<div id="form-success" class="hidden text-center py-12 px-6">
  <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900 mb-4">
    <svg class="w-8 h-8 text-green-600 dark:text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
    </svg>
  </div>
  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Message Sent!</h3>
  <p class="text-gray-600 dark:text-gray-400">
    Thank you for reaching out. Vastu Acharya Minu Saini will get back to you within 24 hours.<br />
    For a faster response, <a
      href="https://wa.me/919972709328?text=Hi%2C%20I%20submitted%20an%20enquiry%20on%20your%20website"
      class="text-amber-600 font-medium hover:underline"
      target="_blank"
      rel="noopener">WhatsApp us directly</a
    >.
  </p>
</div>

<!-- Error state -->
<div
  id="form-error"
  class="hidden mb-4 p-4 rounded-lg bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700"
>
  <p class="text-sm text-red-700 dark:text-red-300 font-medium" id="form-error-msg">
    Something went wrong. Please try again or WhatsApp us directly at +91-99727 09328.
  </p>
</div>

<form id="bhummivastu-contact-form" novalidate>
  <!-- Web3Forms hidden fields -->
  <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
  <input type="hidden" name="subject" value="New Consultation Enquiry — BhummiVastu" />
  <input type="hidden" name="from_name" value="BhummiVastu Website" />
  <!-- Honeypot spam protection -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

  {
    inputs &&
      inputs.map(({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
        name ? (
          <div class="mb-6">
            {label && (
              <label for={name} class="block text-sm font-medium mb-1">
                {label} <span class="text-red-500">*</span>
              </label>
            )}
            <input
              type={type}
              name={name}
              id={name}
              autocomplete={autocomplete}
              placeholder={placeholder}
              required
              data-validate={name}
              class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-amber-400 focus:border-amber-400 outline-none transition"
            />
            <p class="hidden mt-1 text-xs text-red-600 dark:text-red-400" id={`error-${name}`} />
          </div>
        ) : null
      )
  }

  {
    textarea && (
      <div class="mb-6">
        <label for="message" class="block text-sm font-medium mb-1">
          {textarea.label} <span class="text-red-500">*</span>
        </label>
        <textarea
          id="message"
          name={textarea.name ?? 'message'}
          rows={textarea.rows ?? 5}
          placeholder={textarea.placeholder}
          required
          data-validate="message"
          class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 focus:ring-2 focus:ring-amber-400 focus:border-amber-400 outline-none transition resize-none"
        />
        <p class="hidden mt-1 text-xs text-red-600 dark:text-red-400" id="error-message" />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start mb-4">
        <input
          id="disclaimer"
          name="disclaimer"
          type="checkbox"
          required
          class="cursor-pointer mt-1 rounded border-gray-300 text-amber-600 focus:ring-amber-400"
        />
        <label for="disclaimer" class="ml-3 cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
          {disclaimer.label} <span class="text-red-500">*</span>
        </label>
      </div>
    )
  }

  {
    button && (
      <div class="mt-6 grid">
        <Button variant="primary" type="submit" id="submit-btn">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>

<script>
  const form = document.getElementById('bhummivastu-contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const errorMsgEl = document.getElementById('form-error-msg');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  // ── Validation rules ──────────────────────────────────────────────
  const validators: Record<string, { pattern: RegExp; message: string }> = {
    name: {
      pattern: /^[A-Za-z\s]{2,60}$/,
      message: 'Please enter your full name (letters and spaces only).',
    },
    phone: {
      pattern: /^[0-9+\-\s()]{7,20}$/,
      message: 'Please enter a valid phone number (digits, +, -, spaces allowed).',
    },
    email: {
      pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,
      message: 'Please enter a valid email address (e.g. name@example.com).',
    },
    message: {
      pattern: /^[\s\S]{10,}$/,
      message: 'Please enter at least 10 characters describing your requirement.',
    },
  };

  function showFieldError(fieldName: string, message: string) {
    const el = document.getElementById(`error-${fieldName}`);
    const input = document.querySelector(`[data-validate="${fieldName}"]`) as HTMLElement | null;
    if (el) {
      el.textContent = message;
      el.classList.remove('hidden');
    }
    if (input) input.classList.add('border-red-400');
  }

  function clearFieldError(fieldName: string) {
    const el = document.getElementById(`error-${fieldName}`);
    const input = document.querySelector(`[data-validate="${fieldName}"]`) as HTMLElement | null;
    if (el) {
      el.textContent = '';
      el.classList.add('hidden');
    }
    if (input) input.classList.remove('border-red-400');
  }

  function validateForm(data: FormData): boolean {
    let valid = true;
    for (const [field, rule] of Object.entries(validators)) {
      const value = (data.get(field) as string | null)?.trim() ?? '';
      clearFieldError(field);
      if (!rule.pattern.test(value)) {
        showFieldError(field, rule.message);
        valid = false;
      }
    }
    return valid;
  }

  // Live validation on blur
  document.querySelectorAll<HTMLElement>('[data-validate]').forEach((el) => {
    el.addEventListener('blur', () => {
      const field = el.getAttribute('data-validate')!;
      const rule = validators[field];
      if (!rule) return;
      const value = (el as HTMLInputElement | HTMLTextAreaElement).value.trim();
      if (!rule.pattern.test(value)) {
        showFieldError(field, rule.message);
      } else {
        clearFieldError(field);
      }
    });
  });

  // ── Form submission ───────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const data = new FormData(form);

    // Client-side validation
    if (!validateForm(data)) return;

    // Disable button while submitting
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
    }
    errorEl?.classList.add('hidden');

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });

      const result = await response.json();

      if (result.success) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
      } else {
        if (errorMsgEl) errorMsgEl.textContent = result.message ?? 'Submission failed. Please try again.';
        errorEl?.classList.remove('hidden');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      }
    } catch {
      if (errorMsgEl)
        errorMsgEl.textContent =
          'Network error. Please check your connection and try again, or WhatsApp us at +91-99727 09328.';
      errorEl?.classList.remove('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    }
  });
</script>
