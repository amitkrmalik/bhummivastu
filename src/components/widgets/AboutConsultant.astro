---
import { Icon } from 'astro-icon/components';
import { getAsset } from '~/utils/permalinks';

interface Props {
  id?: string;
}
const { id } = Astro.props;

const credentials = [
  {
    icon: 'tabler:certificate',
    text: 'Certified Vastu Acharya with 5+ years of active practice',
  },
  {
    icon: 'tabler:om',
    text: 'Continuous advanced training in traditional Vedic and spiritual disciplines',
  },
  {
    icon: 'tabler:home-check',
    text: 'Non-demolition first approach — practical, modern, non-disruptive',
  },
  {
    icon: 'tabler:users',
    text: '100+ satisfied clients across India — homes, offices & businesses',
  },
  {
    icon: 'tabler:map-pin',
    text: 'Online consultations across India · In-Person in Bangalore & Karnataka',
  },
];
---

<section class="relative not-prose py-16 md:py-24 bg-white dark:bg-slate-900" {...id ? { id } : {}}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section label -->
    <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3 text-center md:text-left">
      About the Consultant
    </p>

    <div class="flex flex-col md:flex-row md:items-center gap-12 md:gap-16">
      <!-- Left — Bio text -->
      <div class="md:basis-1/2">
        <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-gray-900 dark:text-white mb-6">
          Meet <span class="text-accent">Vastu Acharya Minu Saini</span> —<br class="hidden md:block" />
          India's Trusted Vastu &amp; Astrology Consultant
        </h2>

        <div class="space-y-4 text-base md:text-lg text-gray-600 dark:text-slate-400 leading-relaxed">
          <p>
            <strong class="text-gray-800 dark:text-slate-200">BhummiVastu</strong> is a trusted Vastu and Vedic Astrology
            consultancy serving individuals, families, and businesses across India — online from anywhere in the country,
            and in-person for clients in Bangalore and Karnataka. Founded by <strong
              class="text-gray-800 dark:text-slate-200">Vastu Acharya Minu Saini</strong
            >, the practice has guided 100+ clients with practical, personalised solutions rooted in ancient wisdom and
            adapted for modern living.
          </p>
          <p>
            With over <strong class="text-gray-800 dark:text-slate-200">5 years of dedicated practice</strong>, Minu's
            expertise spans residential Vastu for homes and flats, commercial Vastu for offices and startups, and Vedic
            Astrology for career decisions, relationships, and life planning. Her knowledge has been shaped through
            continuous learning and deep engagement with traditional Vedic and spiritual disciplines — enriching her
            understanding of spatial energy, cosmic timing, and the subtle forces that govern well-being.
          </p>
          <p>
            Her approach is refreshingly <strong class="text-gray-800 dark:text-slate-200"
              >non-invasive and non-demolition first</strong
            > — achieving results through the intelligent placement of objects, colours, directions, and energetic remedies,
            not construction. Whether you are seeking a Vastu consultation for your home — anywhere in India — guidance on
            a business decision, or a Jyotish reading for a major life transition, Minu brings the same quality of attention,
            care, and respect for tradition to every engagement.
          </p>
          <p class="text-accent font-semibold">
            BhummiVastu brings together the wisdom of Vastu Shastra and Vedic Astrology to help you move forward with
            confidence, balance, and purpose — wherever you are in life.
          </p>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-accent text-white font-semibold rounded-lg px-6 py-3 hover:bg-accent/90 transition-colors shadow-md"
          >
            <Icon name="tabler:calendar-event" class="w-5 h-5" />
            Book a Consultation
          </a>
          <a
            href="/about"
            class="inline-flex items-center justify-center gap-2 border border-accent text-accent font-semibold rounded-lg px-6 py-3 hover:bg-accent/5 transition-colors"
          >
            Learn More About Minu
            <Icon name="tabler:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Right — Photo + credentials -->
      <div class="md:basis-1/2 flex flex-col items-center gap-6">
        <div class="relative w-full max-w-sm">
          <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-amber-400/20 rounded-2xl -rotate-2"></div>
          <img
            src={getAsset('/images/media/hero-image-minu.jpeg')}
            alt="Vastu Acharya Minu Saini — Vastu and Astrology Consultant, India"
            class="relative rounded-2xl shadow-xl w-full object-cover"
            width="480"
            height="560"
            loading="lazy"
          />
          <div
            class="absolute bottom-4 left-4 right-4 bg-white/90 dark:bg-slate-900/90 rounded-xl px-4 py-3 text-center shadow"
          >
            <p class="font-bold text-gray-900 dark:text-white text-sm">Vastu Acharya Minu Saini</p>
            <p class="text-xs text-muted">Vastu & Astrology Consultant · Pan India</p>
          </div>
        </div>

        <!-- Credentials list -->
        <ul class="w-full max-w-sm space-y-3">
          {
            credentials.map(({ icon, text }) => (
              <li class="flex items-start gap-3 bg-gray-50 dark:bg-slate-800 rounded-xl px-4 py-3">
                <Icon name={icon} class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" />
                <span class="text-sm text-gray-700 dark:text-slate-300">{text}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
