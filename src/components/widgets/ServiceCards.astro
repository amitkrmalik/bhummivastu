---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

interface ServiceCard {
  icon: string;
  title: string;
  description: string;
  medium: string[]; // Each string = one line, rendered with its own icon
  includes: string[]; // 3–4 key deliverables shown on the card
  price: string;
  href: string;
  accent?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  id?: string;
  isDark?: boolean;
  classes?: Record<string, string>;
  bg?: string;
}

const { title = '', subtitle = '', tagline = '', id, isDark = false, classes = {}, bg } = Astro.props;

const mediumIcons: Record<number, string> = {
  0: 'tabler:map-pin', // first line → in-person/location icon
  1: 'tabler:video', // second line → video/online icon
};

const cards: ServiceCard[] = [
  {
    icon: 'tabler:home',
    title: 'Non-Demolition Vastu for Homes & Flats',
    description:
      'Harmonise your home without breaking a single wall. Practical, science-backed Vastu tailored to your floor plan.',
    medium: ['In-Person (Pan India)', 'Online (Zoom / Google Meet)'],
    includes: [
      'Complete 16-Zone Vastu Analysis',
      'Digital Mapping with Floor Plan',
      'Entrance & Room Placement Review',
      'Non-Demolition Remedies + Energy Tips',
    ],
    price: '₹5,000 or ₹20/SFT (50% off)',
    href: '/services/residential-vastu',
    accent: 'text-blue-600',
  },
  {
    icon: 'tabler:building-store',
    title: 'Vastu for Offices & Startups',
    description: 'Align your workspace to attract clients, boost team energy, and accelerate business growth.',
    medium: ['In-Person (Pan India)', 'Online (Zoom / Google Meet)'],
    includes: [
      'Complete 16-Zone Vastu Analysis',
      'Owner/MD Cabin Placement',
      'Staff Seating Arrangement',
      'Cash Counter & Safe Direction',
    ],
    price: '₹10,000 or ₹50/SFT (50% off)',
    href: '/services/commercial-vastu',
    accent: 'text-green-600',
  },
  {
    icon: 'tabler:building-factory',
    title: 'Vastu for Factories & Warehouses',
    description: 'Optimise layout for safety, workflow efficiency, and operational excellence in your industrial unit.',
    medium: ['In-Person (Pan India)', 'Online (Zoom / Google Meet)'],
    includes: [
      'Complete Business Premises Analysis',
      'Energy Scanning & Geopathic Stress Check',
      'Safety & Workflow Zone Corrections',
      'Growth & Productivity Remedies',
    ],
    price: '₹10,000 or ₹50/SFT (25% off, <5,000 SFT)',
    href: '/services/industrial-vastu',
    accent: 'text-orange-600',
  },
  {
    icon: 'tabler:home-star',
    title: 'Astro-Vastu for Homes — Premium',
    description:
      "Your birth chart cross-referenced with your home's Vastu energy. The most powerful home consultation available.",
    medium: ['In-Person (Pan India)', 'Online (Zoom / Google Meet)'],
    includes: [
      '1-Person Birth Chart + Full Vastu Report',
      'Planetary-Space Integration Analysis',
      'Non-Demolition Remedies',
      'Gemstone & Auspicious Timing Guidance',
    ],
    price: '₹10,000 or ₹30/SFT (50% off)',
    href: '/services/astro-vastu',
    accent: 'text-amber-500',
  },
  {
    icon: 'tabler:sparkles',
    title: 'Astro-Vastu for Offices & Industrial — Premium',
    description:
      "Business owner's birth chart meets commercial Vastu for extraordinary, targeted business transformation.",
    medium: ['In-Person (Pan India)', 'Online (Zoom / Google Meet)'],
    includes: [
      'Complete Business Premises Analysis',
      'Energy Scanning + Geopathic Stress Check',
      'Owner/MD Cabin & Staff Seating',
      'Cash Counter, Safe & Growth Remedies',
    ],
    price: '₹25,000 or ₹50/SFT (50% off, >5,000 SFT)',
    href: '/services/astro-vastu-commercial',
    accent: 'text-purple-600',
  },
  {
    icon: 'tabler:device-laptop',
    title: 'Astrology for IT Career & Business Growth',
    description:
      'Navigate career moves, business launches, and growth windows with Vedic planetary timing on your side.',
    medium: ['Online (Zoom / Google Meet)'],
    includes: [
      'Birth Chart Analysis',
      'Planetary Career & Business Influences',
      'Auspicious Timings for Key Decisions',
      'Gemstone Recommendations',
    ],
    price: '₹5,000 · 1-hr session',
    href: '/services/it-career-astrology',
    accent: 'text-indigo-600',
  },
  {
    icon: 'tabler:heart',
    title: 'Astrology for Personal Life & Relationships',
    description: 'Clarity on marriage, family harmony, and well-being through in-depth Vedic birth chart analysis.',
    medium: ['Online (Zoom / Google Meet)'],
    includes: [
      'Birth Chart Analysis',
      'Planetary Life & Relationship Influences',
      'Personalised Remedies + Gemstone Guidance',
      'Auspicious Timings + Direction-based Solutions',
    ],
    price: '₹5,000 · 1-hr session',
    href: '/services/personal-life-astrology',
    accent: 'text-pink-600',
  },
  {
    icon: 'tabler:question-mark',
    title: 'Prashna Kundali — Horary Astrology',
    description:
      'Instant answer to one specific question from the chart cast at the moment of asking. No birth details required.',
    medium: ['Online (WhatsApp / Phone Call)'],
    includes: [
      'Max 1 question per session',
      'No birth details needed',
      'Answer within the 10-min session',
      'Career, property, relationships & more',
    ],
    price: '₹1,000 · 10-min session',
    href: '/services/prashna-kundali',
    accent: 'text-teal-600',
  },
];
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  {
    (title || subtitle || tagline) && (
      <Headline
        title={title}
        subtitle={subtitle}
        tagline={tagline}
        classes={{
          container: 'max-w-xl sm:mx-auto lg:max-w-2xl',
          title: 'text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading',
          subtitle: 'max-w-3xl mx-auto sm:text-center text-xl text-muted dark:text-slate-400',
        }}
      />
    )
  }

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
    {
      cards.map((card) => (
        <a
          href={card.href}
          class="group flex flex-col bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-700 rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
          aria-label={card.title}
        >
          {/* Card top accent bar */}
          <div class="h-1 w-full bg-gradient-to-r from-accent to-blue-400" />

          <div class="flex flex-col flex-1 p-6 gap-3">
            {/* Icon + Medium */}
            <div class="flex items-start justify-between gap-3">
              <div
                class={`w-12 h-12 rounded-xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center flex-shrink-0 ${card.accent ?? 'text-accent'}`}
              >
                <Icon name={card.icon} class="w-7 h-7" />
              </div>
              {/* Medium lines — one per entry, each on its own line */}
              <div class="flex flex-col items-end gap-1 mt-1">
                {card.medium.map((line, i) => (
                  <span class="flex items-center gap-1 text-xs text-muted dark:text-slate-500 leading-none whitespace-nowrap">
                    <Icon
                      name={mediumIcons[i] ?? 'tabler:device-mobile'}
                      class="w-3.5 h-3.5 flex-shrink-0 text-accent"
                    />
                    {line}
                  </span>
                ))}
              </div>
            </div>

            {/* Title */}
            <h3 class="text-base font-bold text-gray-900 dark:text-white group-hover:text-accent transition-colors leading-snug">
              {card.title}
            </h3>

            {/* Description */}
            <p class="text-sm text-muted dark:text-slate-400 leading-relaxed">{card.description}</p>

            {/* What's included */}
            <div class="border-t border-gray-100 dark:border-slate-700 pt-3 mt-1">
              <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wide mb-2">
                What's included
              </p>
              <ul class="space-y-1.5">
                {card.includes.map((item) => (
                  <li class="flex items-start gap-2 text-xs text-gray-600 dark:text-slate-400">
                    <Icon name="tabler:circle-check-filled" class="w-3.5 h-3.5 text-accent flex-shrink-0 mt-0.5" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Price + CTA row */}
            <div class="flex items-center justify-between pt-3 mt-auto border-t border-gray-100 dark:border-slate-700">
              <span class="text-sm font-semibold text-accent">{card.price}</span>
              <span class="text-sm font-semibold text-accent group-hover:underline flex items-center gap-1">
                View Details
                <Icon name="tabler:arrow-right" class="w-4 h-4" />
              </span>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</WidgetWrapper>
