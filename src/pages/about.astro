---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';
import { getAsset } from '~/utils/permalinks';

const metadata = {
  title: 'About Vastu Acharya Minu Saini | Vastu & Astrology Consultant | BhummiVastu',
  description:
    'Meet Vastu Acharya Minu Saini — certified Vastu and Vedic Astrology consultant based in Bangalore. 5+ years of practice, 100+ satisfied clients, non-demolition approach. Serving homes and businesses across India.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero tagline="About BhummiVastu">
    <Fragment slot="title">
      Meet <span class="text-accent dark:text-white">Vastu Acharya Minu Saini</span>
    </Fragment>

    <Fragment slot="subtitle">
      Certified Vastu and Vedic Astrology consultant serving clients across India. Helping individuals, families, and
      businesses create lasting harmony, clarity, and prosperity through the ancient sciences of Vastu Shastra and
      Jyotish — with a modern, practical, non-demolition approach.
    </Fragment>
    <Fragment slot="image">
      <img
        src={getAsset('/images/media/hero-image-minu.jpeg')}
        alt="Vastu Acharya Minu Saini — Vastu & Astrology Consultant, India"
        width="640"
        height="800"
        class="mx-auto rounded-md w-full max-w-md object-cover shadow-xl"
        loading="eager"
      />
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Trust Built Through Results"
    stats={[
      { title: 'Satisfied Clients', amount: '100+' },
      { title: 'Years of Practice', amount: '5+' },
      { title: 'Services Offered', amount: '6' },
      { title: 'Cities Served', amount: 'Pan India' },
    ]}
  />

  <!-- Story & Philosophy ************ -->

  <Features2
    title="The BhummiVastu Story"
    subtitle="BhummiVastu was born from a deep conviction: that the ancient sciences of Vastu Shastra and Vedic Astrology, when applied with integrity and scientific rigour, have the power to transform not just spaces — but lives."
    tagline="Our Story"
    items={[
      {
        title: 'Rooted in Tradition',
        description:
          "Minu Saini's journey into Vastu and Astrology began with years of dedicated study under traditional Vedic masters, absorbing classical texts and practical frameworks that have guided Indian civilisation for millennia.",
        icon: 'tabler:om',
      },
      {
        title: 'Shaped by Modern Practice',
        description:
          'With 5+ years of active consulting across India — online for clients nationwide and in-person across Bangalore and Karnataka — Minu ji has refined her approach through hundreds of real client cases.',
        icon: 'tabler:building',
      },
      {
        title: 'Non-Demolition First',
        description:
          'Every consultation at BhummiVastu begins with a simple commitment: no structural changes, no demolition, no unnecessary expense. Harmony is achieved through colour, direction, elemental placement, and intelligent spatial corrections.',
        icon: 'tabler:home-check',
      },
      {
        title: 'Rooted in Bangalore, Serving India',
        description:
          'Based at Pruksa Silvana, Budigere Cross, Bangalore East. All consultations are available online (Zoom / Google Meet) for clients anywhere in India. In-person sessions are available for clients in Bangalore and Karnataka.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Science, Not Superstition',
        description:
          'Vastu is a science of spatial geometry and elemental energy — not religion or superstition. Every recommendation is explained with directional logic and scientific reasoning so clients are empowered, not dependent.',
        icon: 'tabler:atom',
      },
      {
        title: 'Ethical Always',
        description:
          "BhummiVastu does not use fear, urgency, or exaggerated claims. Every engagement is built on honesty, transparency, and genuine care for the client's well-being and long-term growth.",
        icon: 'tabler:shield-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/60 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Core Values ****************** -->

  <Steps2
    title="How Minu Saini Works"
    subtitle="A transparent, structured approach built on deep analysis, honest communication, and lasting results."
    tagline="The Approach"
    items={[
      {
        title: 'Deep Listening First',
        description:
          'Every engagement begins with understanding your specific challenges — health, career, relationships, finances. Solutions are personalised to your life, not copied from a template.',
      },
      {
        title: 'Precision Analysis',
        description:
          'Using a 16-zone Vastu framework, 45 energy fields, and detailed birth chart analysis (for Astrology and Astro-Vastu), every consultation is forensically thorough.',
      },
      {
        title: 'Clear Communication',
        description:
          'Reports are written in plain language. Every recommendation is explained — why it works, how to implement it, and what outcome to expect. No jargon. No dependency.',
      },
      {
        title: 'Follow-Up Accountability',
        description:
          'A complimentary follow-up review 4–6 weeks after implementation ensures corrections are working and results are tracking as expected.',
      },
    ]}
  />

  <!-- Achievements ****************** -->

  <Steps2
    title="Credentials & Achievements"
    subtitle="Built through years of dedicated study and hundreds of successful client consultations."
    tagline="Recognition"
    isReversed={true}
    callToAction={{
      text: 'View Certifications',
      href: '/certifications',
      icon: 'tabler:certificate',
    }}
    items={[
      {
        title: 'Certified Vastu Acharya',
        description:
          'Formally certified through rigorous training in traditional Vastu Shastra principles, directional science, and Vedic spatial analysis.',
        icon: 'tabler:certificate',
      },
      {
        title: '100+ Satisfied Clients',
        description:
          'Clients served across India — residential homes, commercial offices, startups, industrial units, and Astro-Vastu integrations, from metros to smaller cities.',
        icon: 'tabler:users',
      },
      {
        title: 'Advanced Vedic & Spiritual Training',
        description:
          'Continuous learning in traditional Vedic disciplines, Jyotish (Vedic Astrology), and spiritual sciences — ensuring consultations remain deeply grounded in authentic tradition.',
        icon: 'tabler:book-2',
      },
    ]}
  />

  <!-- Location ********************* -->

  <Features2
    title="Where to Find Us"
    tagline="Our Base"
    columns={2}
    items={[
      {
        title: 'Registered Office',
        description: 'Pruksa Silvana, Budigere Cross, Off Old Madras Road, Bangalore East Tq. — 560049',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Online Consultations',
        description:
          'Serving clients across India via detailed floor plan review, Google Earth mapping, and video call. Distance is no barrier to a personalised consultation.',
        icon: 'tabler:video',
      },
      {
        title: 'Phone & WhatsApp',
        description: '+91-99727 09328 — Call or WhatsApp to discuss your requirements and book a consultation.',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description:
          'minusaini@bhummivastu.com — Reach us for enquiries, floor plan submissions, or detailed questions.',
        icon: 'tabler:mail',
      },
    ]}
  />

  <!-- Final CTA ******************** -->

  <CallToAction
    title="Ready to Begin Your Journey?"
    subtitle="Book a consultation with Vastu Acharya Minu Saini and take the first step toward a life of harmony, clarity, and prosperity."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'Explore Our Services',
        href: '/#services',
      },
    ]}
  />
</Layout>
