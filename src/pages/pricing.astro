---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Consultation Pricing | BhummiVastu | Vastu & Astrology — India',
  description:
    'Transparent consultation pricing for all Vastu and Astrology services by Vastu Acharya Minu Saini. Available online across India and in-person in Bangalore & Karnataka. Every package includes 30 days of follow-up support.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Pricing"
    title="Transparent Consultation Pricing"
    subtitle="Honest, upfront pricing for every service — no hidden charges, no surprises. All packages include a written report and 30 days of follow-up questions."
  />

  <!-- Vastu Services Pricing ******** -->

  <Features2
    title="Vastu Shastra Consultation Pricing"
    subtitle="Pricing is based on property size (SFT = square feet). Discounts apply when you book early. Every consultation includes a written Vastu report and 30 days of follow-up Q&A."
    tagline="Vastu Services"
    columns={3}
    items={[
      {
        title: 'Residential Vastu — Homes & Flats',
        description:
          '**₹5,000 flat fee** or **₹20/SFT** with 50% discount on the per-SFT rate. Includes: 1-hour live consultation (video call for all India / in-person for Bangalore & Karnataka), full 16-zone Vastu analysis, zero-demolition remedy report, and 30 days of follow-up questions.',
        icon: 'tabler:home',
      },
      {
        title: 'Commercial Vastu — Offices & Startups',
        description:
          '**₹10,000 minimum** or **₹50/SFT** with 50% discount on the per-SFT rate. Includes: 1-hour live consultation, workspace directional analysis, non-demolition correction report, and 30 days of follow-up questions.',
        icon: 'tabler:building-store',
      },
      {
        title: 'Industrial Vastu — Factories & Warehouses',
        description:
          '**₹10,000 minimum** or **₹50/SFT** with 25% discount (for spaces under 5,000 SFT). Includes: 2-hour live consultation, safety and productivity zone analysis, written report, and 30 days of follow-up questions.',
        icon: 'tabler:building-factory',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50/40 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Astro-Vastu Pricing ********** -->

  <Features2
    title="Astro-Vastu Premium Pricing"
    subtitle="The most comprehensive offering — your birth chart integrated with your Vastu space analysis for a deeply personalised, transformative result."
    tagline="Astro-Vastu Premium"
    columns={2}
    items={[
      {
        title: 'Astro-Vastu for Homes — Premium',
        description:
          '**₹10,000 flat fee** or **₹30/SFT** with 50% discount on the per-SFT rate. Includes: 2-hour live consultation, full Vastu + Jyotish integration analysis, personalised remedy report, and 30 days of follow-up questions.',
        icon: 'tabler:home-star',
      },
      {
        title: 'Astro-Vastu for Offices / Startups / Factories / Warehouses — Premium',
        description:
          '**₹25,000 flat fee** or **₹50/SFT** with 50% discount (for spaces above 5,000 SFT). Includes: 2-hour live consultation, business owner birth chart + commercial Vastu integration, written report, and 30 days of follow-up questions.',
        icon: 'tabler:sparkles',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/40 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Astrology Pricing ************ -->

  <Features2
    title="Vedic Astrology Consultation Pricing"
    subtitle="Fixed-fee sessions with a written summary and 30 days of follow-up questions. No birth details required for Prashna Kundali."
    tagline="Astrology Services"
    columns={3}
    items={[
      {
        title: 'IT Career & Business Growth Astrology',
        description:
          '**₹5,000 · 1-hour session.** Career moves, business launch timing, salary negotiation windows, and planetary period analysis. Includes written summary and 30 days of follow-up questions.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Personal Life & Relationships Astrology',
        description:
          '**₹5,000 · 1-hour session.** Marriage timing, compatibility, family harmony, health patterns, and life direction from your Vedic birth chart. Includes written report and 30 days of follow-up questions.',
        icon: 'tabler:heart',
      },
      {
        title: 'Prashna Kundali — Horary Astrology',
        description:
          '**₹1,000 · 10-minute session.** Instant answer to one specific question — no birth details required. Cast from the moment of asking. Available via WhatsApp or phone call.',
        icon: 'tabler:question-mark',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-purple-50/30 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Inclusions Summary *********** -->

  <Features2
    title="What Every Consultation Includes"
    tagline="Always Included"
    subtitle="No matter which service you choose, these are standard inclusions with every BhummiVastu consultation."
    columns={2}
    items={[
      {
        title: 'Live Consultation Session',
        description:
          'A structured live session — by video call (Zoom / Google Meet) for clients anywhere in India, or in-person for Bangalore and Karnataka clients. Duration: 10 min (Prashna Kundali), 1 hour (Vastu & Astrology), 2 hours (Industrial & Astro-Vastu Premium).',
        icon: 'tabler:video',
      },
      {
        title: 'Written Report Delivered',
        description:
          'A comprehensive PDF report with zone-wise recommendations (Vastu) or chart analysis summary (Astrology) — including remedies, implementation steps, and guidance. Your reference document for the journey ahead.',
        icon: 'tabler:file-text',
      },
      {
        title: '30 Days of Follow-Up Questions',
        description:
          'All consultations (except Prashna Kundali) include 30 days of follow-up questions via WhatsApp or email. You are never left alone during implementation — ask anything that comes up.',
        icon: 'tabler:message-2',
      },
      {
        title: 'Zero-Demolition Vastu Corrections',
        description:
          'Every Vastu service uses only non-invasive, non-demolition remedies — colour therapy, directional repositioning, elemental placements. No structural changes, no unnecessary expense.',
        icon: 'tabler:home-check',
      },
    ]}
  />

  <!-- FAQs ************************* -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Common questions about consultation fees, what's included, and how it works."
    columns={1}
    items={[
      {
        title: 'How is the Vastu consultation fee calculated — flat fee or per-SFT?',
        description:
          'For Residential Vastu, you pay ₹5,000 flat (ideal for smaller homes or if you prefer a fixed cost) OR ₹20/SFT with a 50% discount on the per-SFT rate. For a 1,000 SFT flat: ₹20 × 1,000 × 50% = ₹10,000 → but the flat ₹5,000 would apply if it is lower. Minu ji will advise the applicable rate based on your property size when you book.',
      },
      {
        title: 'What does "30 days of follow-up questions" mean?',
        description:
          'After your consultation, you can send follow-up questions via WhatsApp or email for 30 days. This covers implementation doubts, clarifications on the report, questions that arise as you make changes, and confirmation that you have applied remedies correctly. It is included in the consultation fee — no extra charge.',
      },
      {
        title: 'What is the difference between Vastu and Astro-Vastu?',
        description:
          'Vastu analyses your physical space against universal directional principles. Astro-Vastu also reads the birth charts of the inhabitants and cross-references them with the Vastu zones — making corrections far more personalised. Astro-Vastu typically costs more because it requires both a full Vastu survey and a complete astrological analysis.',
      },
      {
        title: 'Are in-person consultations available outside Bangalore?',
        description:
          'In-person site visits are available for clients in Bangalore and across Karnataka within the standard consultation fee. For clients in other states who prefer an in-person visit, travel charges apply and are agreed in advance. Most clients across India prefer the online mode (Zoom / Google Meet), which is just as thorough.',
      },
      {
        title: 'What payment methods are accepted?',
        description:
          'We accept UPI (Google Pay, PhonePe, Paytm), bank transfer (NEFT/IMPS), and cash for in-person consultations. Payment details will be shared upon booking confirmation.',
      },
      {
        title: 'Is the initial enquiry free?',
        description:
          'Yes — the initial WhatsApp message or call to discuss your requirements and understand which service is right for you is completely free. A fee applies only once a formal consultation is confirmed.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to Book Your Consultation?"
    subtitle="Reach out via WhatsApp or the contact form — Vastu Acharya Minu Saini will confirm your slot within 24 hours."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: getPermalink('/contact'),
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'WhatsApp Us',
        href: 'https://wa.me/919972709328?text=Hi%2C%20I%20would%20like%20to%20book%20a%20consultation.',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />
</Layout>
