---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import ServiceCards from '~/components/widgets/ServiceCards.astro';
import Mission from '~/components/widgets/Mission.astro';
import AboutConsultant from '~/components/widgets/AboutConsultant.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';
import { featuredTestimonials, averageRating, totalReviews, getInitials, serviceList } from '~/data/testimonials';

const avatarColors = [
  'bg-amber-100 text-amber-700',
  'bg-blue-100 text-blue-700',
  'bg-green-100 text-green-700',
  'bg-purple-100 text-purple-700',
  'bg-rose-100 text-rose-700',
  'bg-teal-100 text-teal-700',
];
function stars(r: number) {
  return Array.from({ length: 5 }, (_, i) => (i < r ? '★' : '☆')).join('');
}

const metadata = {
  title: 'Best Vastu & Astrology Consultant in Bangalore | Minu Saini | Online Across India',
  description:
    'Top-rated Vastu & Astrology consultant — Vastu Acharya Minu Saini. Online consultations across India. In-person in Bangalore & Karnataka. Non-demolition Vastu, Vedic Astrology, Astro-Vastu. 100+ satisfied clients.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      { text: 'Our Services', href: '#services' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Vastu Acharya Minu Saini (photo TBD)' }}
  >
    <Fragment slot="title">
      <span class="block text-3xl md:text-5xl font-bold leading-tight">
        Meet <span class="text-accent">Vastu Acharya Minu Saini</span>
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="block mb-2 font-semibold text-primary dark:text-blue-300 text-lg md:text-2xl"
        >Unlock Harmony & Prosperity — Wherever You Are in India</span
      >
      <span class="block text-base md:text-lg mb-2"
        >Authentic Vastu and Astrology guidance for your home, office, and life — available online across India, with
        in-person visits in Bangalore and Karnataka.</span
      >
      <span class="block text-amber-700 font-semibold text-sm md:text-base mb-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="inline-block h-5 w-5 text-amber-500 mr-1"
          viewBox="0 0 24 24"
          fill="currentColor"
          ><path
            d="M12 2a7 7 0 0 1 7 7c0 2.39-1.26 4.48-3.15 5.65l.65 2.6c.13.53-.16 1.08-.68 1.21-.53.13-1.08-.16-1.21-.68l-.6-2.4c-.34.04-.69.07-1.01.07s-.67-.03-1.01-.07l-.6 2.4c-.13.52-.68.81-1.21.68-.52-.13-.81-.68-.68-1.21l.65-2.6A6.99 6.99 0 0 1 5 9a7 7 0 0 1 7-7zm0 2a5 5 0 0 0-5 5c0 1.77.93 3.32 2.33 4.21.31.19.47.56.38.91l-.47 1.89.47-1.89c.09-.35.4-.59.76-.59h2c.36 0 .67.24.76.59l.47 1.89-.47-1.89a.75.75 0 0 1 .38-.91A5.002 5.002 0 0 0 17 9a5 5 0 0 0-5-5z"
          ></path></svg
        >
        Trusted Vastu & Astrology consultant — online across India
      </span>
      <span class="block text-amber-700 font-semibold text-sm md:text-base">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="inline-block h-5 w-5 text-amber-500 mr-1"
          viewBox="0 0 24 24"
          fill="currentColor"
          ><path
            d="M12 2a7 7 0 0 1 7 7c0 2.39-1.26 4.48-3.15 5.65l.65 2.6c.13.53-.16 1.08-.68 1.21-.53.13-1.08-.16-1.21-.68l-.6-2.4c-.34.04-.69.07-1.01.07s-.67-.03-1.01-.07l-.6 2.4c-.13.52-.68.81-1.21.68-.52-.13-.81-.68-.68-1.21l.65-2.6A6.99 6.99 0 0 1 5 9a7 7 0 0 1 7-7zm0 2a5 5 0 0 0-5 5c0 1.77.93 3.32 2.33 4.21.31.19.47.56.38.91l-.47 1.89.47-1.89c.09-.35.4-.59.76-.59h2c.36 0 .67.24.76.59l.47 1.89-.47-1.89a.75.75 0 0 1 .38-.91A5.002 5.002 0 0 0 17 9a5 5 0 0 0-5-5z"
          ></path></svg
        >
        100+ happy clients and success stories
      </span>
      <!-- TODO: Insert actual consultant photo and credentials when available -->
    </Fragment>
  </Hero>

  <!-- Service Cards ******************* -->

  <ServiceCards
    id="services"
    tagline="Our Expertise"
    title="How Can We Help You?"
    subtitle="From harmonising your home to unlocking your career's full potential — explore our services and find the right fit for you."
  />

  <!-- Mission & Philosophy ******************* -->

  <Mission id="mission" />

  <!-- About the Consultant ******************* -->

  <AboutConsultant id="about" />

  <!-- Core Values (Sprint 5A) ******************* -->

  <Features2
    id="values"
    tagline="Our Foundations"
    title="What We Stand For"
    subtitle="Five principles that guide every consultation — and every result we help you achieve."
    items={[
      {
        title: 'Scientific Logic',
        description:
          'Vastu is a science of energy and spatial geometry, not a set of religious rules. We explain the "how" and "why" behind every suggestion so you feel confident — not confused — about the results.',
        icon: 'tabler:atom',
      },
      {
        title: 'Zero-Demolition Practicality',
        description:
          'We respect your existing space. Our remedies focus on non-disruptive corrections — using colours, elements, and precise placements — to achieve harmony without any demolition or reconstruction.',
        icon: 'tabler:home-check',
      },
      {
        title: 'Ethical Integrity',
        description:
          'Our guidance is grounded in honesty. We never use fear or exaggerated claims to drive decisions. We provide only what is necessary for your well-being and growth, with complete transparency throughout.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Client-Centric Empathy',
        description:
          "Every individual's journey is unique. We listen deeply to your specific concerns — career, health, or relationships — and tailor our Astro-Vastu solutions to support your personal goals and lifestyle.",
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Empowerment Through Knowledge',
        description:
          "We don't just fix spaces; we empower people. We educate our clients on how to maintain a high-vibrational environment, making harmony a permanent part of their lives long after the consultation ends.",
        icon: 'tabler:book-2',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/60 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- How a Consultation Works (Sprint 5B) ******************* -->

  <Steps
    id="process"
    tagline="The Process"
    title="Your Journey to Harmony — 5 Simple Steps"
    subtitle="A structured, transparent process designed to deliver real, measurable results — for your home, office, or life."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Discovery &amp; Data Sharing</span>',
        description:
          'Share your current life challenges along with your property floor plan and birth details. This foundational data allows us to map your unique energy blueprint — ensuring every recommendation is grounded in your specific reality, not a generic template.',
        icon: 'tabler:message-share',
      },
      {
        title: 'Step 2: <span class="font-medium">Technical Survey &amp; Directional Mapping</span>',
        description:
          'We perform precise directional mapping using Google Earth for online sessions — available for clients across India — or an on-site visit for those in Bangalore and Karnataka, to identify hidden Vastu Doshas affecting health, relationships, and finances.',
        icon: 'tabler:compass',
      },
      {
        title: 'Step 3: <span class="font-medium">16-Zone Zonal Analysis</span>',
        description:
          'Vastu Acharya Minu Saini conducts a deep-dive analysis of your space across 16 directions and 45 energy fields, cross-referencing them with your astrological planetary periods (Dashas) for a truly integrated Astro-Vastu diagnosis.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Step 4: <span class="font-medium">Live Consultation &amp; Written Report</span>',
        description:
          'Receive a detailed written report followed by a dedicated video call or in-person meeting. Every zero-demolition remedy is explained with its scientific and directional reasoning — so you understand the "why," not just the "what."',
        icon: 'tabler:video',
      },
      {
        title: 'Step 5: <span class="font-medium">Implementation &amp; Follow-Up Support</span>',
        description:
          'Harmony is a journey, not a one-time event. We offer complimentary follow-up support to confirm remedies are correctly implemented and to track measurable shifts in energy, well-being, and results over time.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Vastu Acharya Minu Saini analysing a floor plan — BhummiVastu consultation process',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50 dark:bg-transparent"></div>
    </Fragment>
  </Steps>

  <!-- ── Testimonials (Homepage Strip) ─────────────────────────── -->
  <section class="py-14 md:py-18 bg-white dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="text-center mb-10">
        <p class="text-xs font-bold tracking-widest uppercase text-accent mb-2">Client Reviews</p>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">Trusted by Clients Across India</h2>
        <!-- Google aggregate badge -->
        <div
          class="inline-flex items-center gap-3 mt-4 bg-amber-50 dark:bg-slate-800 border border-amber-200 dark:border-amber-900/50 rounded-full px-5 py-2"
        >
          <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none">
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              fill="#4285F4"></path>
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"></path>
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
              fill="#FBBC05"></path>
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"></path>
          </svg>
          <span class="text-amber-500 text-sm font-bold">{stars(Math.round(averageRating))}</span>
          <span class="text-sm font-semibold text-gray-700 dark:text-slate-300"
            >{averageRating} · {totalReviews} Google Reviews</span
          >
        </div>
      </div>

      <!-- Featured review cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        {
          featuredTestimonials.slice(0, 3).map((t, i) => (
            <div class="relative flex flex-col bg-gradient-to-br from-amber-50 to-orange-50 dark:from-slate-800 dark:to-slate-800 border border-amber-200 dark:border-amber-800/50 rounded-2xl p-5 shadow-md">
              <span
                aria-hidden="true"
                class="absolute top-3 right-4 text-5xl text-amber-200 dark:text-amber-900/60 font-serif leading-none select-none"
              >
                "
              </span>
              <div class="text-amber-400 text-base mb-2 leading-none">{stars(t.rating)}</div>
              <blockquote class="flex-1 text-sm text-gray-700 dark:text-slate-300 leading-relaxed mb-4 line-clamp-4">
                {t.text}
              </blockquote>
              <div class="flex items-center gap-2 pt-3 border-t border-amber-200 dark:border-amber-900/40">
                <div
                  class={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs flex-shrink-0 ${avatarColors[i % avatarColors.length]}`}
                >
                  {getInitials(t.name, t.initials)}
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 dark:text-white truncate">{t.name}</p>
                  {t.location && <p class="text-xs text-muted truncate">{t.location}</p>}
                </div>
              </div>
              {serviceList(t.service).length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1">
                  {serviceList(t.service).map((s) => (
                    <span class="inline-block text-xs bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 rounded-full px-2.5 py-0.5 font-medium">
                      {s}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))
        }
      </div>

      <!-- Link to full page -->
      <div class="text-center">
        <a
          href="/testimonials"
          class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:underline"
        >
          Read all {totalReviews} reviews
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- ── Final CTA ─────────────────────────────────────────────── -->
  <CallToAction
    title="Ready to Transform Your Space & Life?"
    subtitle="Book a consultation with Vastu Acharya Minu Saini — available online across India and in-person in Bangalore & Karnataka."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'View Services & Pricing',
        href: '/pricing',
      },
    ]}
  />
</Layout>
