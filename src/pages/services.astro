---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Vastu & Astrology Services | BhummiVastu | Bangalore & Online Across India',
  description:
    'Vastu and Astrology services by Vastu Acharya Minu Saini — online for clients across India, in-person in Bangalore & Karnataka. Residential Vastu, Commercial Vastu, Industrial Vastu, Astrology, and Astro-Vastu Premium.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Our Services"
    title="Vastu & Astrology Consultations Tailored for Your Life"
    subtitle="From harmonising your home to navigating your career path — BhummiVastu offers six specialised services grounded in authentic Vedic wisdom and delivered with modern precision."
    actions={[
      { variant: 'primary', text: 'Book a Consultation', href: '/contact', icon: 'tabler:calendar-event' },
      {
        text: 'Talk to Us on WhatsApp',
        href: 'https://wa.me/919972709328?text=Hi%2C%20I%20would%20like%20to%20know%20more%20about%20your%20Vastu%20and%20Astrology%20services.',
        target: '_blank',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=900&q=80',
      alt: 'Serene, harmonious living space — BhummiVastu services across India',
    }}
  />

  <!-- Vastu Services *************** -->

  <Features2
    title="Vastu Shastra Services"
    subtitle="Science-backed spatial alignment for homes, offices, and industrial units — with a zero-demolition, non-invasive approach."
    tagline="Vastu Services"
    items={[
      {
        title: 'Residential Vastu — Homes & Flats',
        description:
          'Create a home that nurtures peace, health, and prosperity. Personalised 16-zone Vastu analysis with written report and follow-up. Starting from ₹5,000 or ₹20/SFT.',
        icon: 'tabler:home',
      },
      {
        title: 'Commercial Vastu — Offices & Startups',
        description:
          'Align your workspace to attract clients, boost team energy, and accelerate business growth. Covers reception, cabins, workstations, cash zones. Starting from ₹10,000 or ₹50/SFT.',
        icon: 'tabler:building-store',
      },
      {
        title: 'Industrial Vastu — Factories & Warehouses',
        description:
          'Optimise your industrial unit for safety, workflow efficiency, and operational excellence. Directional analysis of entry, production floor, and storage zones. ₹50/SFT.',
        icon: 'tabler:building-factory',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50/40 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Astrology Services *********** -->

  <Features2
    title="Vedic Astrology Services"
    subtitle="Ancient Jyotish science applied to modern life challenges — career, relationships, and personal growth."
    tagline="Astrology Services"
    items={[
      {
        title: 'IT Career & Business Growth Astrology',
        description:
          'Navigate career moves, salary negotiations, business launches, and growth windows with planetary timing on your side. Ideal for IT professionals and entrepreneurs. ₹5,000 · 1-hour session.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Personal Life & Relationships Astrology',
        description:
          'Find clarity on marriage timing, compatibility, family harmony, health patterns, and personal life direction through in-depth birth chart analysis. ₹5,000 · 1-hour session.',
        icon: 'tabler:heart',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/40 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Astro-Vastu Premium ********** -->

  <Features2
    title="Astro-Vastu — Premium Integration"
    subtitle="The most holistic offering: your birth chart meets your physical space for a deeply personalised, transformative analysis."
    tagline="Premium Service"
    items={[
      {
        title: 'Astro-Vastu for Homes',
        description:
          "Your planetary blueprint cross-referenced with your home's Vastu zones. Reveals how your personal energies interact with your living space and delivers integrated remedies for both. Starting from ₹5,000 or ₹20/SFT.",
        icon: 'tabler:home-star',
      },
      {
        title: 'Astro-Vastu for Offices, Startups & Industrial',
        description:
          "Premium Astro-Vastu for commercial and industrial spaces — combining the business owner's planetary periods with the workspace's directional energy for powerful, targeted growth strategies. Contact us for pricing.",
        icon: 'tabler:sparkles',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-purple-50/30 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Why BhummiVastu ************** -->

  <Steps
    title="Why Clients Choose BhummiVastu"
    tagline="Our Difference"
    subtitle="Six principles that make every BhummiVastu consultation an investment, not an expense."
    items={[
      {
        title: 'Zero-Demolition Approach',
        description:
          'No walls broken. No structural changes. Harmony achieved through colour, direction, and elemental placement — practical and cost-effective.',
        icon: 'tabler:home-check',
      },
      {
        title: 'Science-Based Explanations',
        description:
          'Every recommendation comes with a clear directional and scientific rationale. You understand why you are making a change — not just what to change.',
        icon: 'tabler:atom',
      },
      {
        title: 'Integrated Astro-Vastu',
        description:
          'Unique capability to combine Vastu Shastra and Vedic Astrology in a single consultation — addressing your space and your cosmic blueprint together.',
        icon: 'tabler:stars',
      },
      {
        title: 'Pan-India Online Consultations',
        description:
          'Detailed floor plan analysis and Google Earth mapping enables precise online consultations for clients anywhere in India.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Written Reports Included',
        description:
          'Every consultation includes a comprehensive written report with zone-wise recommendations, implementation steps, and colour/placement guidance.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Complimentary Follow-Up',
        description: 'A follow-up review 4–6 weeks after implementation ensures results are tracking as expected.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&q=80',
      alt: 'Vastu consultation in progress — BhummiVastu',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50 dark:bg-transparent"></div>
    </Fragment>
  </Steps>

  <!-- Testimonials ***************** -->

  <Testimonials
    title="What Our Clients Say"
    tagline="Client Stories"
    testimonials={[
      {
        testimonial: `After my Residential Vastu consultation with Minu ji, we noticed a marked improvement in our family's harmony and financial stability within just 2 months. The best part — not a single wall was touched. Highly recommended for anyone looking for genuine Vastu guidance.`,
        name: 'Priya R.',
        job: 'Homeowner, Whitefield, Bengaluru',
      },
      {
        testimonial: `We were struggling with cash flow and team retention in our startup. Minu ji's Commercial Vastu analysis identified key directional imbalances and provided simple, actionable fixes. Results were visible within a quarter.`,
        name: 'Arvind M.',
        job: 'Co-founder, Tech Startup, Koramangala',
      },
      {
        testimonial: `The Astrology session for my IT career was incredibly accurate. Minu ji identified the exact period for my job switch and it played out exactly as she said. She is genuine, knowledgeable, and deeply caring.`,
        name: 'Suresh K.',
        job: 'Senior Software Engineer, Indiranagar',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/40 dark:bg-transparent"></div>
    </Fragment>
  </Testimonials>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to Transform Your Space & Life?"
    subtitle="Book a consultation with Vastu Acharya Minu Saini and take the first step toward harmony, clarity, and lasting prosperity."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'WhatsApp Us Now',
        href: 'https://wa.me/919972709328?text=Hi%2C%20I%20would%20like%20to%20know%20more%20about%20your%20services.',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />
</Layout>
