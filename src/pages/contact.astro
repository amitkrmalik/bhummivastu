---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Vastu Acharya Minu Saini | Book a Vastu & Astrology Consultation in Bangalore',
  description:
    'Get in touch with Vastu Acharya Minu Saini for Vastu and Astrology consultations in Bangalore. Call, WhatsApp, or email to book your personalised session.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Contact Us"
    title="Book Your Consultation"
    subtitle="Reach out via WhatsApp, call, or email — Vastu Acharya Minu Saini is here to guide you toward harmony, clarity, and prosperity."
  />

  <ContactUs
    id="form"
    title="Send Us a Message"
    subtitle="Fill in your details below and we will get back to you within 24 hours to confirm your consultation slot."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Full Name',
        placeholder: 'e.g. Ramesh Sharma',
        autocomplete: 'name',
      },
      {
        type: 'tel',
        name: 'phone',
        label: 'Phone / WhatsApp Number',
        placeholder: '+91-99999 99999',
        autocomplete: 'tel',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email Address',
        placeholder: 'e.g. ramesh@example.com',
        autocomplete: 'email',
      },
    ]}
    textarea={{
      label: 'Your Message / Requirement',
      name: 'message',
      placeholder: 'e.g. I am looking for a Residential Vastu consultation for my 2BHK flat in Whitefield, Bangalore. The flat is approximately 1,100 SFT...',
      rows: 5,
    }}
    disclaimer={{
      label:
        'By submitting this form, I voluntarily consent to sharing my personal details with BhummiVastu for the purpose of consultation enquiry, and I agree to the Terms & Conditions and Privacy Policy.',
    }}
    button="Send Enquiry"
    description="We typically respond within 24 hours. For faster response, WhatsApp us directly at +91-99727 09328."
  />

  <!-- Contact Details ************** -->

  <Features2
    title="Reach Us Directly"
    tagline="Contact Details"
    columns={3}
    items={[
      {
        title: 'WhatsApp & Phone',
        description: '+91-99727 09328 — WhatsApp preferred for quick responses. Also available for calls during business hours.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Email',
        description: 'minusaini@bhummivastu.com — For floor plan submissions, detailed enquiries, and report deliveries.',
        icon: 'tabler:mail',
      },
      {
        title: 'Office Address',
        description: 'Pruksa Silvana, Budigere Cross, Off Old Madras Road, Bangalore East Tq. — 560049',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Quick Links ****************** -->

  <Features2
    title="What to Expect"
    tagline="Your Journey Begins Here"
    columns={2}
    items={[
      {
        title: 'Residential Vastu',
        description:
          'Share your floor plan, home address, and family details. We will assess your space and provide a non-demolition remedy report. Starting from ₹5,000.',
        icon: 'tabler:home',
      },
      {
        title: 'Commercial Vastu',
        description:
          'Office or startup Vastu consultation to improve team energy, client flow, and business growth. Starting from ₹10,000.',
        icon: 'tabler:building-store',
      },
      {
        title: 'Astrology Reading',
        description:
          'Share your birth date, time, and place for a personalised Vedic Astrology reading — career, relationships, or life planning. ₹5,000 for a 1-hour session.',
        icon: 'tabler:stars',
      },
      {
        title: 'Astro-Vastu Premium',
        description:
          'The most comprehensive offering — combining your birth chart with your space analysis for an integrated, personalised transformation plan.',
        icon: 'tabler:sparkles',
      },
    ]}
  />
</Layout>
