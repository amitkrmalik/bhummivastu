---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Certifications & Awards | Vastu Acharya Minu Saini | BhummiVastu',
  description:
    'View the certifications, training credentials, and recognition earned by Vastu Acharya Minu Saini — Vastu and Astrology consultant serving clients across India.',
};

// ── Certificate images go in: src/assets/images/certifications/
// Copy JPEGs there and add entries below.
// Then also copy them to public/images/certifications/ so the <img> src resolves.
//
// Format: { title, issuer, year, image }
//   image = filename only, e.g. 'vastu-acharya-2020.jpg'

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. "/bhummivastu" or ""
const mentorPhoto = `${base}/images/media/MahaVastu-Expert_pic_1.jpeg`;
const pinnaclePhoto = `${base}/images/media/Pinnacle-Vastu-Siddhi-Course-pic-1.jpeg`;

const certImages: Array<{ title: string; issuer: string; year: string; image: string }> = [
  // ── Paste entries here once JPEGs are added ──
  {
    title: 'MahaVastu Foundation Course Jan-Feb 2023',
    issuer: 'MahaVastu',
    year: '2023',
    image: 'cert-MahaVastu-Foundation-Course-Jan-Feb-2023.jpg',
  },
  {
    title: 'Astro-MahaVastu Remedies Course Sept-Oct 2023',
    issuer: 'MahaVastu',
    year: '2023',
    image: 'cert-Astro-MahaVastu-Remedies-2023-sept-oct.jpg',
  },
  {
    title: 'Astro-MahaVastu Remedies Course Nov-Dec 2023',
    issuer: 'MahaVastu',
    year: '2023',
    image: 'cert-Astro-MahaVastu-Remedies-2023-nov-dec.jpg',
  },
  {
    title: 'Advance Vastu Course Dec 2023',
    issuer: 'Acharya Vikul Bansal - Pinnacle Vastu',
    year: '2023',
    image: 'cert-Advance-Vastu-Course-Dec-2023.jpg',
  },
  {
    title: 'KP ASTROLOGY, BNN ASTROLOGY, ADVANCE VASTU, ASTRO VASTU, GPS ASTROLOGY AND TATOO ACTIVATION',
    issuer: 'SHREE RAJIV MODGIL JI - ASTRO KP',
    year: '2025',
    image: 'cert-KP-ASTRO-BNN-2025-Nov.jpg',
  },
  {
    title: 'Professional Vastu & Numerology Jan 2024',
    issuer: 'Acharya Vikul Bansal - Pinnacle Vastu',
    year: '2024',
    image: 'cert-Professional-Vastu-Numerology-Jan-2024.jpg',
  },
];

const continuousLearning = [
  {
    title: 'Vastu Shastra — Advanced Directional Analysis',
    description:
      'Deep training in the 16-zone Vastu framework, 45 energy fields, directional mapping, and non-demolition remedy systems for residential and commercial spaces.',
    icon: 'tabler:compass',
  },
  {
    title: 'Vedic Astrology (Jyotish)',
    description:
      'Comprehensive study of Vedic birth chart analysis, Dasha systems, planetary periods, and their application to career, relationships, health, and life planning.',
    icon: 'tabler:stars',
  },
  {
    title: 'Astro-Vastu Integration',
    description:
      'Specialised training in cross-referencing Jyotish birth charts with Vastu spatial analysis — the unique methodology behind the Astro-Vastu Premium service.',
    icon: 'tabler:sparkles',
  },
  {
    title: 'Traditional Vedic & Spiritual Sciences',
    description:
      'Ongoing engagement with traditional Vedic texts, spiritual disciplines, and contemporary applications — ensuring consultations remain rooted in authentic tradition.',
    icon: 'tabler:om',
  },
];
---

<Layout metadata={metadata}>
  <!-- ── Hero ──────────────────────────────────────────── -->
  <HeroText
    tagline="Credentials"
    title="Certifications & Recognition"
    subtitle="The knowledge and credentials behind every BhummiVastu consultation — built through years of dedicated study, practice, and continuous learning."
  />

  <!-- ── Mentor & Recognition ─────────────────────────── -->
  <section class="pb-8 md:pb-12 max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="grid lg:grid-cols-[1.05fr_0.95fr] gap-8 items-center rounded-[2rem] border border-amber-200/70 dark:border-amber-900/40 bg-gradient-to-br from-amber-50 via-orange-50 to-yellow-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 p-6 md:p-8 shadow-lg"
    >
      <a
        href={mentorPhoto}
        target="_blank"
        rel="noopener"
        class="block overflow-hidden rounded-2xl border border-amber-200 dark:border-amber-900/40 bg-white dark:bg-slate-900 shadow-md"
        title="View full photo"
      >
        <img
          src={mentorPhoto}
          alt="Vastu Acharya Minu Saini with Vastu Acharya Sri Khushdeep Bansal at a MahaVastu recognition moment"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </a>

      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3">Mentorship & Recognition</p>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white leading-tight">
          Guided by Guru & Margdarshak
        </h2>
        <p class="mt-4 text-base text-gray-700 dark:text-slate-300 leading-relaxed">
          This milestone captures Vastu Acharya Minu Saini with
          <strong class="text-amber-800 dark:text-amber-300">Vastu Acharya Sri Khushdeep Bansal</strong>
          — a revered Guru and Margdarshak in the MahaVastu tradition whose guidance helped shape her discipline, clarity,
          and commitment to responsible practice.
        </p>
        <p class="mt-4 text-base text-gray-700 dark:text-slate-300 leading-relaxed">
          His teachings deepened her understanding of Vastu, occult disciplines, and the sacred responsibility of
          walking the path of
          <strong class="text-amber-800 dark:text-amber-300">dharma</strong> with sincerity, service, and integrity.
        </p>

        <div class="mt-5 flex flex-wrap gap-2">
          {
            ['MahaVastu Tradition', 'Guru Guidance', 'Path of Dharma'].map((label) => (
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-white/80 text-amber-800 border border-amber-200 dark:bg-slate-800 dark:text-amber-300 dark:border-amber-900/40">
                {label}
              </span>
            ))
          }
        </div>

        <blockquote
          class="mt-6 rounded-2xl border border-amber-200/70 dark:border-amber-900/40 bg-white/80 dark:bg-slate-800/80 p-5"
        >
          <p class="text-base md:text-lg font-medium text-amber-900 dark:text-amber-200 leading-relaxed">
            “Rooted in authentic guidance. Practised with dharma. Shared with responsibility.”
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="pb-10 md:pb-14 max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="grid lg:grid-cols-[0.95fr_1.05fr] gap-8 items-center rounded-[2rem] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 md:p-8 shadow-md"
    >
      <div class="order-2 lg:order-1">
        <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3">Spiritual Learning & Discipline</p>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white leading-tight">
          Guided in Sadhna & Siddhi by Sri Acharya Vikul Bansal
        </h2>
        <p class="mt-4 text-base text-gray-700 dark:text-slate-300 leading-relaxed">
          This moment reflects another important chapter in Minu Saini’s learning journey — receiving guidance from
          <strong class="text-amber-800 dark:text-amber-300">Sri Acharya Vikul Bansal</strong>, whose teachings helped
          deepen her connection to the divine world of
          <strong class="text-amber-800 dark:text-amber-300">sadhna</strong> and
          <strong class="text-amber-800 dark:text-amber-300">siddhi</strong>.
        </p>
        <p class="mt-4 text-base text-gray-700 dark:text-slate-300 leading-relaxed">
          His guidance strengthened the inner discipline, devotion, and spiritual steadiness that support Minu ji’s
          practice — complementing technical knowledge with a more inward path of refinement and responsibility.
        </p>

        <div class="mt-5 flex flex-wrap gap-2">
          {
            ['Pinnacle Vastu', 'Sadhna & Siddhi', 'Inner Discipline'].map((label) => (
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold bg-slate-50 text-slate-700 border border-slate-200 dark:bg-slate-800 dark:text-slate-300 dark:border-slate-700">
                {label}
              </span>
            ))
          }
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://www.acharyavikulbansal.in/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-300 dark:border-slate-700 px-5 py-2.5 text-sm font-semibold text-slate-900 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
          >
            Visit Acharya Vikul Bansal
            <span class="sr-only">(opens in new tab)</span>
          </a>
          <a
            href={pinnaclePhoto}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-amber-300 dark:border-amber-800/50 px-5 py-2.5 text-sm font-semibold text-amber-900 dark:text-amber-300 hover:bg-amber-50 dark:hover:bg-slate-800 transition-colors"
          >
            Open Full Photo
          </a>
        </div>
      </div>

      <a
        href={pinnaclePhoto}
        target="_blank"
        rel="noopener"
        class="order-1 lg:order-2 block overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 shadow-sm"
        title="View full photo"
      >
        <img
          src={pinnaclePhoto}
          alt="Vastu Acharya Minu Saini with Sri Acharya Vikul Bansal during an educational program"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </a>
    </div>
  </section>

  <!-- ── Expertise Areas ───────────────────────────────── -->
  <Features2
    title="Areas of Deep Expertise"
    subtitle="Vastu Acharya Minu Saini's knowledge spans traditional Vastu Shastra, Vedic Astrology, and the unique integration of both — developed through formal training and 5+ years of active practice."
    tagline="Expertise"
    items={continuousLearning}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50/60 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- ── Formal Certifications ─────────────────────────── -->
  <section class="py-16 md:py-20 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <p class="text-xs font-bold tracking-widest uppercase text-accent mb-3">Certifications</p>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">Formal Certifications & Awards</h2>
      {
        certImages.length === 0 && (
          <p class="mt-4 text-base text-muted dark:text-slate-400 max-w-xl mx-auto">
            Formal certifications and awards are being compiled and will be published here shortly. Check back soon.
          </p>
        )
      }
    </div>

    {
      certImages.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {certImages.map(({ title, issuer, year, image }) => (
            <div class="group flex flex-col rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-md hover:shadow-xl transition-shadow duration-300">
              <a
                href={`${base}/images/certifications/${image}`}
                target="_blank"
                rel="noopener"
                title={`View full certificate — ${title}`}
                class="block overflow-hidden bg-amber-50 dark:bg-slate-800"
              >
                <img
                  src={`${base}/images/certifications/${image}`}
                  alt={`${title} certificate — ${issuer}, ${year}`}
                  class="w-full object-contain max-h-64 p-4 group-hover:scale-[1.02] transition-transform duration-300"
                  loading="lazy"
                />
              </a>
              <div class="p-5 flex flex-col gap-1 border-t border-gray-100 dark:border-gray-700">
                <h3 class="font-bold text-gray-900 dark:text-white text-base leading-snug">{title}</h3>
                <p class="text-sm text-amber-700 dark:text-amber-400 font-medium">{issuer}</p>
                <p class="text-xs text-muted mt-1">Awarded: {year}</p>
              </div>
            </div>
          ))}
        </div>
      )
    }
  </section>

  <!-- ── Stats ─────────────────────────────────────────── -->
  <section class="py-12 bg-slate-50 dark:bg-slate-800/30">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {
          [
            { label: 'Satisfied Clients', value: '100+' },
            { label: 'Years of Practice', value: '5+' },
            { label: 'Services Offered', value: '8' },
            { label: 'Consultation Mode', value: 'Online & In-Person' },
          ].map(({ label, value }) => (
            <div>
              <p class="text-3xl md:text-4xl font-bold text-accent">{value}</p>
              <p class="text-sm text-muted mt-1">{label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <CallToAction
    title="Experience Expertise First-Hand"
    subtitle="Book a consultation with Vastu Acharya Minu Saini and see the depth of knowledge applied to your specific situation — online for clients across India."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'Explore Services',
        href: '/services',
      },
    ]}
  />
</Layout>
