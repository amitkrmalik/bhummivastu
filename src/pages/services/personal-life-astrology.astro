---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Astrology for Personal Life & Relationships | Vastu Acharya Minu Saini | Online India | Vastu Acharya Minu Saini',
  description:
    'Find clarity on marriage, relationships, family harmony, and personal well-being with personalised Vedic Astrology by Vastu Acharya Minu Saini across India. Kundali Milan and life guidance.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Astrology — Personal Life"
    title="Astrology for Personal Life & Relationships in Bangalore"
    subtitle="From marriage timing and Kundali Milan to family harmony and personal well-being — gain deep, compassionate insight into your life journey and the relationships that shape it."
  />

  <!-- Pricing Banner -->
  <section class="bg-pink-50 dark:bg-pink-900/20 border-y border-pink-200 dark:border-pink-800 py-4">
    <div class="max-w-4xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left">
      <div>
        <span class="font-bold text-pink-800 dark:text-pink-200 text-base">₹5,000 · 1-hour session</span>
        <span class="block text-xs text-pink-700 dark:text-pink-400 mt-0.5">Includes: 1-hour live video consultation · Personal guidance report & remedies · 30 days of follow-up questions</span>
      </div>
      <a href="/contact" class="shrink-0 inline-flex items-center gap-2 bg-accent text-white font-semibold text-sm rounded-lg px-4 py-2 hover:bg-accent/90 transition-colors">
        Book Now
      </a>
    </div>
  </section>

  <!-- What is Personal Life Astrology -->
  <Content
    tagline="About This Service"
    title="Your Life's Blueprint — Understanding the Patterns That Shape You"
    content={`
      <p>Life's most meaningful questions — when to marry, how to navigate a relationship challenge, what the chart reveals about family harmony, or how to deal with recurring health patterns — find illuminating answers in your Vedic birth chart. Vastu Acharya Minu Saini provides deeply empathetic, personalised Astrology consultations for personal life, relationships, and well-being.</p>
      <p>A Vedic birth chart is a complete cosmic blueprint of your life's potential, patterns, and timing. The 7th house governs marriage and partnerships; the 2nd and 4th houses reflect family and domestic harmony; the 5th house guides matters of children and creativity; while the 6th, 8th, and 12th houses reveal health and karmic patterns. Minu ji analyses these houses — along with divisional charts (Navamsa for marriage, Ashtamsa for longevity) and current planetary transits — to give you a nuanced, honest, and compassionate reading of your personal life.</p>
      <p>This service is ideal for individuals facing a crossroads in relationships, seeking guidance on marriage compatibility (<strong>Kundali Milan</strong>), navigating family disputes, supporting a child's development decisions, understanding recurring health challenges, or simply wanting clarity about the deeper patterns shaping their life. Available by video call — consultations for clients across India and abroad.</p>
    `}
    items={[
      {
        title: 'Birth Chart Analysis',
        description: 'Complete Vedic Janma Kundali — all 12 houses, key divisional charts (Navamsa for marriage, Ashtamsa for challenges), and current planetary periods.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Planetary Influences on Personal Life',
        description: 'Identifies how current and upcoming planetary periods specifically affect your relationships, family harmony, health, and personal growth.',
        icon: 'tabler:stars',
      },
      {
        title: 'Personalised Vastu Remedies',
        description: 'Home and living space direction-based suggestions aligned to your chart — to create a physical environment that supports your personal planetary energy.',
        icon: 'tabler:home',
      },
      {
        title: 'Gemstone Recommendations',
        description: 'Planetary gemstone guidance tailored to your birth chart — supporting love, family harmony, health, and personal well-being.',
        icon: 'tabler:diamond',
      },
      {
        title: 'Auspicious Timings',
        description: 'Muhurta guidance for marriage dates, engagement ceremonies, property purchases, and other major personal life decisions.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Direction-based Solutions + 1-Hr Consultation + 30 Days Support',
        description: 'Compass direction guidance for sleeping, study, and daily routines. Includes 1-hour Zoom/Meet session and 30 days of follow-up Q&A.',
        icon: 'tabler:compass',
      },
    ]}
    columns={2}
    image={{
      src: 'https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?w=800&q=80',
      alt: 'Personal life guidance and relationship clarity — Astrology by BhummiVastu Bangalore',
    }}
  />

  <!-- Process Steps -->
  <Steps
    title="How a Personal Life Astrology Consultation Works"
    tagline="Our Process"
    items={[
      {
        title: 'Share Birth Details & Your Questions',
        description:
          'Provide your birth date, exact time of birth, and place of birth. For compatibility or Kundali Milan, share your partner\'s details too. Include the specific life areas or questions you would like the consultation to focus on.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Comprehensive Chart Preparation',
        description:
          'Minu ji analyses your natal chart alongside relevant divisional charts — Navamsa (D-9) for marriage and relationships, Ashtamsa (D-8) for challenges and longevity, and other divisional charts specific to your concerns. For Kundali Milan, both charts are assessed together.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Empathetic 60-Minute Consultation',
        description:
          'A compassionate, honest, and detailed session — exploring your chart findings in relation to your specific questions. Minu ji focuses on empowering you with understanding and practical guidance, not fear-based predictions.',
        icon: 'tabler:video',
      },
      {
        title: 'Personal Guidance Report & Remedies',
        description:
          'A written report with personalised remedies (mantras, gemstone guidance, auspicious timings for key decisions, lifestyle recommendations) and a clear overview of the year ahead in your key areas of concern.',
        icon: 'tabler:circle-check',
      },
    ]}
    classes={{ container: 'bg-slate-50 dark:bg-slate-800/30' }}
  />

  <!-- CTA -->
  <CallToAction
    title="Bring Clarity & Harmony to Your Life"
    subtitle="Book a personal astrology session with Vastu Acharya Minu Saini — compassionate, honest, and rooted in authentic Vedic wisdom."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'Explore Other Services',
        href: '/#services',
      },
    ]}
  />
</Layout>
