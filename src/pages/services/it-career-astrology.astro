---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title:
    'Astrology for IT Career & Business Growth | Vastu Acharya Minu Saini | Online India | Vastu Acharya Minu Saini',
  description:
    'Navigate career transitions, business launches, and growth decisions with personalised Vedic Astrology by Vastu Acharya Minu Saini — trusted by IT professionals and entrepreneurs across India.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Astrology — IT Career & Business"
    title="Astrology for IT Careers & Business Growth in Bangalore"
    subtitle="Whether you are weighing a job offer, planning a startup launch, or navigating a complex business decision — let Vedic Astrology bring you clarity on timing, risk, and opportunity."
  />

  <!-- Pricing Banner -->
  <section class="bg-indigo-50 dark:bg-indigo-900/20 border-y border-indigo-200 dark:border-indigo-800 py-4">
    <div
      class="max-w-4xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left"
    >
      <div>
        <span class="font-bold text-indigo-800 dark:text-indigo-200 text-base">₹5,000 · 1-hour session</span>
        <span class="block text-xs text-indigo-700 dark:text-indigo-400 mt-0.5"
          >Includes: 1-hour live video consultation · Written summary & Muhurta guidance · 30 days of follow-up
          questions</span
        >
      </div>
      <a
        href="/contact"
        class="shrink-0 inline-flex items-center gap-2 bg-accent text-white font-semibold text-sm rounded-lg px-4 py-2 hover:bg-accent/90 transition-colors"
      >
        Book Now
      </a>
    </div>
  </section>

  <!-- What is IT Career Astrology -->
  <Content
    tagline="About This Service"
    title="Cosmic Timing for Your Career & Business — A Vedic Perspective"
    content={`
      <p>The tech world moves fast — job switches, freelance transitions, startup launches, international opportunities, and high-stakes business decisions all carry timing-sensitive risks and rewards. Vedic Astrology offers a uniquely powerful framework for IT professionals and entrepreneurs: by analysing your <strong>Janma Kundali</strong> (birth chart) alongside the current planetary periods (Dashas) and transits, Vastu Acharya Minu Saini identifies the precise windows of opportunity and caution in your professional life.</p>
      <p>This is not fatalism — it is <strong>informed strategy</strong>. Your birth chart reveals the underlying rhythms of your career and financial life: when planetary support is strong (ripe for negotiation, new ventures, or bold moves) and when caution and consolidation serve you better. Knowing the difference is a genuine competitive edge. Minu ji has helped IT engineers navigate promotions, startup founders identify ideal product launch windows, and small business owners decode persistent financial cycles — all through systematic Vedic astrological analysis.</p>
      <p>The consultation covers career timing and job transitions, business launch Muhurtas (auspicious timing), partnership and co-founder compatibility, financial cycles, and strategic decision windows. Available online — consultations by video call for clients across India.</p>
    `}
    items={[
      {
        title: 'Birth Chart Analysis',
        description:
          'Complete Vedic Janma Kundali analysis — all 12 houses, key planets, and divisional charts relevant to your career, finances, and business.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Planetary Influences on Career & Business',
        description:
          'Identifies the current Mahadasha and Antardasha and their specific impact on your professional trajectory, opportunities, and risk windows.',
        icon: 'tabler:stars',
      },
      {
        title: 'Personalised Remedies',
        description:
          'Targeted Vedic remedies — mantras, lifestyle adjustments, and directional practices — to strengthen favourable planets and mitigate challenges.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Gemstone Recommendations',
        description:
          'Planetary gemstone guidance based on your birth chart — which stones to wear, which to avoid, and how to activate them correctly.',
        icon: 'tabler:diamond',
      },
      {
        title: 'Auspicious Timings (Muhurta)',
        description:
          'Specific auspicious time windows for job applications, interviews, business launches, contract signings, and investment decisions.',
        icon: 'tabler:calendar-event',
      },
      {
        title: '1-Hour Consultation (Zoom/Meet) + 30 Days Follow-up Support',
        description:
          'A 1-hour live video session via Zoom or Google Meet, plus 30 days of WhatsApp/email follow-up for questions on implementation and timing.',
        icon: 'tabler:clock',
      },
    ]}
    columns={2}
    isReversed={true}
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80',
      alt: 'IT professional planning career — Astrology for IT Careers by BhummiVastu',
    }}
  />

  <!-- Process Steps -->
  <Steps
    title="How an IT Career & Business Astrology Consultation Works"
    tagline="Our Process"
    items={[
      {
        title: 'Share Your Birth Details',
        description:
          'Provide your birth date, exact time of birth, and place of birth. These three data points are the only inputs needed to build your complete Janma Kundali. The more precise your birth time, the more accurate the analysis.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Chart Preparation & Dasha Analysis',
        description:
          'Minu ji prepares your natal chart and identifies the current Mahadasha and Antardasha (planetary periods), key transits affecting your career, financial, and professional houses — with specific focus on the 2nd, 6th, 10th, and 11th houses for career and income.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Live 60-Minute Consultation',
        description:
          'A structured video session covering your current planetary period, key career opportunities and caution windows in the next 12–18 months, specific guidance for your stated goals (job change, business launch, etc.), and practical planetary remedies.',
        icon: 'tabler:video',
      },
      {
        title: 'Written Report & Muhurta Recommendations',
        description:
          'Receive a written summary with specific auspicious time windows (Muhurtas) for major career decisions, a 12-month planetary forecast for your key areas, and practical remedies — mantras, lifestyle adjustments, and timing guidance.',
        icon: 'tabler:circle-check',
      },
    ]}
    classes={{ container: 'bg-slate-50 dark:bg-slate-800/30' }}
  />

  <!-- CTA -->
  <CallToAction
    title="Take Charge of Your Career & Business Future"
    subtitle="Book a personalised astrology session with Vastu Acharya Minu Saini and make your next move with confidence and cosmic clarity."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: '/contact',
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'Explore Other Services',
        href: '/#services',
      },
    ]}
  />
</Layout>
