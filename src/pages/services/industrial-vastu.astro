---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Industrial Vastu Consultant | Vastu Acharya Minu Saini | Online India | Vastu for Factories & Warehouses',
  description:
    'Improve safety, productivity, and operational efficiency with Industrial Vastu by Vastu Acharya Minu Saini across India. Expert Vastu Shastra for factories, warehouses, and industrial units.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    tagline="Industrial Vastu"
    title="Vastu for Factories & Warehouses in Bangalore"
    subtitle="A well-aligned industrial space reduces accidents, improves workflow efficiency, and drives operational excellence. Expert Industrial Vastu guidance tailored to your site layout and production goals."
  />

  <!-- Pricing Banner -->
  <section class="bg-orange-50 dark:bg-orange-900/20 border-y border-orange-200 dark:border-orange-800 py-4">
    <div
      class="max-w-4xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left"
    >
      <div>
        <span class="font-bold text-orange-800 dark:text-orange-200 text-base">₹10,000 minimum</span>
        <span class="text-orange-700 dark:text-orange-300 text-sm"> or </span>
        <span class="font-bold text-orange-800 dark:text-orange-200 text-base"
          >₹50/SFT (25% discount, under 5,000 SFT)</span
        >
        <span class="block text-xs text-orange-700 dark:text-orange-400 mt-0.5"
          >Includes: 2-hour live consultation · Priority Vastu report · 30 days of follow-up questions</span
        >
      </div>
      <a
        href={getPermalink('/contact')}
        class="shrink-0 inline-flex items-center gap-2 bg-accent text-white font-semibold text-sm rounded-lg px-4 py-2 hover:bg-accent/90 transition-colors"
      >
        Book Now
      </a>
    </div>
  </section>

  <!-- What is Industrial Vastu -->
  <Content
    tagline="About This Service"
    title="Industrial Vastu — The Spatial Science of Operational Excellence"
    content={`
      <p>Every factory, warehouse, and industrial facility operates within an energy field that significantly influences safety, workflow, machinery performance, and overall productivity. Industrial Vastu Shastra applies the 16-zone directional mapping system to large-scale industrial plots, identifying energy imbalances that contribute to workplace accidents, supply chain inefficiencies, high employee turnover, and persistent operational losses.</p>
      <p>Industrial Vastu is a spatial science grounded in directional principles. The orientation of the main gate, the placement of heavy machinery, the direction of storage and dispatch areas, the location of HR and management offices, and even the position of the water source all carry measurable energy implications for the facility as a whole. Minu ji brings deep expertise in Industrial Vastu, working with factory owners and logistics operators to identify and correct these imbalances through <strong>practical, cost-effective methods</strong> that do not require shutdowns or structural rebuilds.</p>
      <p>Available for manufacturing plants, warehouses, logistics hubs, processing units, cold storage facilities, and construction sites. On-site industrial surveys are available within 200km of Bangalore; remote consultations via detailed site plan are available nationwide.</p>
    `}
    items={[
      {
        title: 'Complete Business Premises Analysis',
        description:
          'Comprehensive Vastu assessment of your entire industrial site — main gate, production floor, storage zones, management offices, and utilities.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Energy Scanning with Tools',
        description:
          'Systematic energy scanning of all functional zones using precision compass and spatial analysis tools to identify Vastu Doshas and energy drains.',
        icon: 'tabler:scan',
      },
      {
        title: 'Geopathic Stress Check',
        description:
          'Assessment of underground geopathic stress lines that can silently cause accidents, health issues, and persistent machinery breakdowns in industrial units.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Safety & Workflow Zone Corrections',
        description:
          'Directional corrections to the fire zone, heavy machinery placement, dispatch areas, and entry/exit points to reduce accident risk and optimise workflow.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Growth & Profit Remedies',
        description:
          'Targeted Vastu remedies to activate the wealth, growth, and prosperity zones of your industrial property for improved output and financial performance.',
        icon: 'tabler:trending-up',
      },
      {
        title: '2-Hour Consultation + 30 Days Follow-up Support',
        description:
          'A 2-hour live session via Zoom/Meet or on-site visit for clients in Bangalore & Karnataka, plus 30 days of WhatsApp/email support for implementation.',
        icon: 'tabler:clock',
      },
    ]}
    columns={2}
    image={{
      src: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=800&q=80',
      alt: 'Industrial facility assessment — Industrial Vastu by BhummiVastu Bangalore',
    }}
  />

  <!-- Process Steps -->
  <Steps
    title="How Industrial Vastu Works — 4 Steps to an Optimised Facility"
    tagline="Our Process"
    items={[
      {
        title: 'Site Profile & Remote Satellite Review',
        description:
          'Share the industrial plot location, layout plan, key operational pain points, and any recurring issues (accidents, delays, attrition). Minu ji conducts an initial remote assessment using satellite imagery and compass data.',
        icon: 'tabler:file-text',
      },
      {
        title: 'On-Site Directional Survey',
        description:
          'Minu ji conducts a detailed on-site survey with precision compass mapping of all 16 Vastu zones, assessing machinery positions, gate directions, storage areas, production zones, management offices, and water/fire sources.',
        icon: 'tabler:compass',
      },
      {
        title: 'Vastu Dosha Analysis & Safety-Energy Audit',
        description:
          'Cross-referencing the site plan with Vastu directional principles to identify zones that generate hazard risk, productivity loss, or financial drain — with clear explanations of the energy mechanism behind each finding.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'Phased Remediation Recommendations',
        description:
          'A practical, priority-ranked action plan — from immediate low-cost corrections (directional repositioning, elemental placements) to medium-term strategic adjustments. Includes a written report with implementation timeline.',
        icon: 'tabler:circle-check',
      },
    ]}
    classes={{ container: 'bg-slate-50 dark:bg-slate-800/30' }}
  />

  <!-- CTA -->
  <CallToAction
    title="Optimise Your Industrial Space"
    subtitle="Connect with Vastu Acharya Minu Saini to assess your factory or warehouse and unlock its true operational potential."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultation',
        href: getPermalink('/contact'),
        icon: 'tabler:calendar-event',
      },
      {
        variant: 'secondary',
        text: 'Explore Other Services',
        href: `${getPermalink('/')}#services`,
      },
    ]}
  />
</Layout>
